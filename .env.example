# Core auth/bootstrap
RAG_FEEDER_JWT_SECRET=replace-with-a-random-long-secret
RAG_ADMIN_USER=admin
RAG_ADMIN_PASSWORD=replace-with-admin-password

# Public app URL
RAG_FEEDER_FRONTEND_URL=https://corpus4uol.university-of-labour.de

# LLM / metadata APIs
# Set either GOOGLE_API_KEY or GEMINI_API_KEY. Keeping both blank is valid only if you do not run extraction/enrichment.
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENALEX_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
RAG_FEEDER_MAILTO=

# Optional throughput tuning
RAG_FEEDER_OPENALEX_RPS=30
RAG_FEEDER_CROSSREF_RPS=20
RAG_FEEDER_SEMANTIC_SCHOLAR_RPS=1
RAG_FEEDER_SEMANTIC_SCHOLAR_MIN_INTERVAL_SEC=1.1
RAG_FEEDER_ENRICH_WORKERS=6
RAG_FEEDER_DOWNLOAD_WORKERS=32
RAG_FEEDER_DOWNLOAD_BATCH_SIZE=50
RAG_FEEDER_DOWNLOAD_BATCH_MAX=2000

# Optional SMTP for invite/reset mail.
# If unset, invite delivery falls back to console logging / preview URLs.
RAG_FEEDER_SMTP_HOST=smtp.example.com
RAG_FEEDER_SMTP_PORT=587
RAG_FEEDER_SMTP_SECURE=false
RAG_FEEDER_SMTP_USER=replace-with-smtp-user
RAG_FEEDER_SMTP_PASS=replace-with-smtp-password
RAG_FEEDER_SMTP_FROM=no-reply@example.com
RAG_FEEDER_SMTP_TLS_REJECT_UNAUTHORIZED=true
RAG_FEEDER_SMTP_IGNORE_TLS=false